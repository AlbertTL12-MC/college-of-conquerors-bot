# Copy this file's contents into Railway's Variables tab — do NOT commit a real .env to GitHub.

DISCORD_TOKEN=your-bot-token-here
GUILD_ID=your-server-id-here

# Optional: path for persistent storage (bans, warnings, blacklist).
# Point this at a mounted Railway Volume, e.g. /data, so data survives redeploys.
DATA_DIR=./data

# Optional: included in the DM staff-approved-appeal message.
SERVER_INVITE_LINK=https://discord.gg/your-invite
